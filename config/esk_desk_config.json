{
  "_paths_comment": "Portable paths: ${HOUFIN_DATA}/${HOUFIN_PROCESSED} expand at load (src/config_utils.py; default <repo>/data and <repo>/data/processed locally, override via env on HPC). NOTE: the DESK/encoder pipeline is a later milestone; this layout is provisional and its stream wiring (2-stream state_*_bio_ema10 -> N-stream state_*) is still to be reconciled.",
  "paths": {
    "data_dir": "${HOUFIN_DATA}",
    "hist_dir": "${HOUFIN_PROCESSED}/encoder/states",
    "ebird_folder": "${HOUFIN_DATA}/ebird_weekly_2023_grid",
    "esk_output_dir": "${HOUFIN_PROCESSED}/encoder/esk",
    "desk_output_dir": "${HOUFIN_PROCESSED}/encoder/desk"
  },
  "esk": {
    "pattern": "*_abundance_median_2023-*.tif",
    "sigmas": [0.0, 0.5, 1.0, 1.5],
    "latent_dims": [8, 16, 32],
    "n_landmarks": 18000
  },
  "desk": {
    "epochs": 100,
    "lr": 0.001,
    "batch_size": 4096,
    "weights": {
      "stabilizing": 1.0,
      "metric": 5.0,
      "reconstruction": 0.1
    },
    "train_val_split": 0.8,
    "z_dir": "${HOUFIN_PROCESSED}/encoder/esk/sigma_1.5"
  },
  "latent_cube": {
    "data_dir": "${HOUFIN_DATA}",
    "hist_dir": "${HOUFIN_PROCESSED}/encoder/states/yearly_states",
    "z_dir": "${HOUFIN_PROCESSED}/encoder/esk/sigma_1.5",
    "model_path": "${HOUFIN_PROCESSED}/encoder/desk/env_model_semisup.pth",
    "z_ref_path": "${HOUFIN_PROCESSED}/encoder/esk/sigma_1.5/Z.npy",
    "mask_ref_path": "${HOUFIN_PROCESSED}/encoder/esk/sigma_1.5/valid_mask.npy",
    "water_mask_path": "${HOUFIN_DATA}/land_mask/ocean_mask_25km.tif",
    "output_dir": "${HOUFIN_PROCESSED}/encoder/cube",
    "state_pattern": "state_*.npz",
    "radius_px": 25
  },
  "single_year_analysis": {
    "esk_feature_path": "${HOUFIN_PROCESSED}/encoder/esk/sigma_0.5/Z.npy",
    "desk_feature_path": "${HOUFIN_PROCESSED}/encoder/cube/Z_latent_2023.npy",
    "mask_path": "${HOUFIN_PROCESSED}/encoder/esk/sigma_0.5/valid_mask.npy",
    "response_path": "${HOUFIN_DATA}/ebird_weekly_2023_grid/houfin_abundance_seasonal_year_round_mean_2023_grid.tif",
    "output_dir": "${HOUFIN_PROCESSED}/encoder/analysis/single_year",
    "comparison_output_dir": "${HOUFIN_PROCESSED}/encoder/analysis/esk_desk_comparison"
  }
}
